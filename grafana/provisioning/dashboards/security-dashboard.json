
{
  "title": "Security Container Quality",
  "panels": [
    {
      "title": "Всего обработано",
      "targets": [{ "expr": "security_processed_total" }],
      "type": "stat"
    },
    {
      "title": "Блокировки vs Разрешения",
      "targets": [
        { "expr": "security_blocked_total", "legendFormat": "Заблокировано" },
        { "expr": "security_allowed_total", "legendFormat": "Разрешено" }
      ],
      "type": "timeseries"
    },
    {
      "title": "Доступность",
      "targets": [{ "expr": "security_up" }],
      "type": "stat"
    }
  ]
}

